# Browser provider: "stagehand-local" (default), "browserbase", or "local"
BROWSER_PROVIDER=stagehand-local

# Anthropic API key — used by Stagehand for AI-powered browser actions
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Target MyChart instance URL
# UCSF example: https://ucsfmychart.ucsfmedicalcenter.org/ucsfmychart/Authentication/Login?
# Use the full URL of the login page for your MyChart instance
MYCHART_URL=https://mychart.yourprovider.org/mychart

# MyChart credentials (optional — if set, skips interactive prompts)
MYCHART_USERNAME=your_username
MYCHART_PASSWORD=your_password

# Set to "true" to run local browser headless (default: visible window)
# HEADLESS=true

# --- Gmail auto-2FA (optional) ---
# If set, the agent will automatically read the MyChart verification code
# from your Gmail inbox instead of requiring manual entry.
#
# How to get an App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Generate a password for "Mail"
#   4. Paste the 16-character password below (no spaces)
#
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=abcdabcdabcdabcd

# --- Only needed for BROWSER_PROVIDER=browserbase ---
# BROWSERBASE_API_KEY=bb_live_xxxxx
# BROWSERBASE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
